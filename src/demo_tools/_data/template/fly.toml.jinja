app = "{{ name }}"
primary_region = "lhr"

[build]

[http_service]
  internal_port = {{ internal_port }}
  force_https = true
  auto_stop_machines = "stop"
  auto_start_machines = true
  min_machines_running = 0

[[vm]]
  size = "shared-cpu-1x"
  memory = "256mb"
{% if stateful %}

[mounts]
  source = "{{ name | replace('-', '_') }}_data"
  destination = "/data"
  initial_size = "1gb"
{% endif %}
