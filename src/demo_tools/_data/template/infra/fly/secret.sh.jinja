#!/usr/bin/env bash
# MANAGED BY demo-tools — DO NOT EDIT. Run `just sync` to update.
set -euo pipefail
APP="{{ name }}"
KV="${1:-}"
if [[ -z "$KV" ]]; then
    echo "Usage: just secret KEY=VALUE" >&2
    exit 1
fi
{% if stack == "nextjs-fastapi" -%}
TARGET="${TARGET:-api}"  # default to api; override with TARGET=web
fly secrets set --app "${APP}-${TARGET}" "$KV"
{%- else -%}
fly secrets set --app "$APP" "$KV"
{%- endif %}
